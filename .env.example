DATABASE_URL="file:./dev.db"

# Optional: Finnhub API key (https://finnhub.io/register) for live market quotes and news.
# If unset, quotes are fetched from Yahoo Finance.
# FINNHUB_API_KEY=

# Gemini LLM layer (Phase 3) — https://aistudio.google.com/apikey
# When set, agent narratives and executive summary are enriched via Gemini.
# GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
