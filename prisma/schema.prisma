generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Holding {
  id            String    @id @default(cuid())
  symbol        String
  shares        Float
  purchasePrice Float
  purchaseDate  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
