generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Holding {
  id            String    @id @default(cuid())
  symbol        String
  quoteSymbol   String?
  assetType     String    @default("stock")
  shares        Float
  purchasePrice Float
  purchaseCurrency String @default("USD")
  purchaseDate  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reports       AnalysisReport[]
}

model PortfolioSettings {
  id        String   @id @default("default")
  cashUsd   Float    @default(0)
  cashEur   Float    @default(0)
  updatedAt DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  symbol      String
  quoteSymbol String?
  assetType   String   @default("stock")
  companyName String?
  shares      Float
  price       Float
  currency    String   @default("USD")
  amount      Float
  costBasis   Float?
  gainLossAbs Float?
  gainLossPct Float?
  createdAt   DateTime @default(now())
}

model WatchlistItem {
  id          String   @id @default(cuid())
  symbol      String   @unique
  quoteSymbol String?
  assetType   String   @default("stock")
  companyName String?
  note        String?
  targetPrice Float?
  createdAt   DateTime @default(now())
}

model AnalysisReport {
  id                String   @id @default(cuid())
  symbol            String
  holdingId         String?
  holding           Holding? @relation(fields: [holdingId], references: [id], onDelete: SetNull)
  recommendation    String
  confidence        Float
  executiveSummary  String
  agentOutputs      String
  companyIntro      String?
  timing            String?
  timingDisclaimer  String?
  analysisMode      String   @default("rules")
  llmModel          String?
  createdAt         DateTime @default(now())
}
